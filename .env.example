# Klean AI — public Supabase configuration
#
# Copy this file to `.env` (never commit `.env`) and fill in the values from
# your Supabase project: https://supabase.com/dashboard/project/_/settings/api
#
# Both variables are prefixed with EXPO_PUBLIC_ so they are available to the
# Expo client at runtime via `process.env`. The anon key is *not* secret in the
# Supabase model — it is gated by Row Level Security policies. Never put the
# service-role key here or in any EXPO_PUBLIC_ variable.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# AI vision provider mode.
#   - unset / "mock"          → MockAIProvider (default — no network call)
#   - "edge-function"         → real Gemini call via the Supabase Edge Function
#                               `analyze-fridge-images`. Requires `GEMINI_API_KEY`
#                               set as a Supabase secret (NOT in this file) and
#                               the function deployed.
EXPO_PUBLIC_AI_PROVIDER=mock
